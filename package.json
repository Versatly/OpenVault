{
  "name": "openvault",
  "version": "0.1.0",
  "description": "Local-first agent memory via MCP. Works with Cursor, Claude Code, and any MCP client.",
  "type": "module",
  "main": "dist/vault.js",
  "bin": {
    "openvault": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent",
    "cursor",
    "claude",
