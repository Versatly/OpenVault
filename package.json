  "author": "Versatly Holdings",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^3.4.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
